# ─────────────────────────────────────────────────────────────
# QR Shipment App — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase Project URL (Settings → API → Project URL) ──────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# ── Supabase Anon / Public Key (Settings → API → anon/public) ─
# Safe to expose in the browser. RLS controls what anon users can do.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role Key (Settings → API → service_role) ─
# ⚠️  SECRET — never expose this in the browser.
# Used only in server-side API routes & server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Sheets Sync API Key ─────────────────────────────────
# Dùng để xác thực khi Google Sheet gọi API đồng bộ.
# Tạo key ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_API_KEY=your-random-sync-key-here
