# ══════════════════════════════════════════════════════════════
# BlackStone Order SCM — Production Environment
# Copy file này → .env.production rồi điền giá trị thật
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://woqtdgzldkxmcgjshthx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Sync & Security ──────────────────────────────────────────
SYNC_API_KEY=your-sync-api-key
CRON_SECRET=your-cron-secret

# ── 1Office Integration ─────────────────────────────────────
ONEOFFICE_API_KEY=your-1office-key
ONEOFFICE_BASE_URL=https://cloud-cloud.1office.vn
ONEOFFICE_INVENTORY_TOKEN=your-inventory-token
ONEOFFICE_WAREHOUSE_TOKEN=your-warehouse-token
